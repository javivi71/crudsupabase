h2= "Listado de productos"
    head    
        title= title
        // link= (href='estilo.css' rel='stylesheet')
        style   
            include estilo.css
    body 
        h1= "Listado de productos"
        a(href='/nuevo') Añadir producto
        a(href='/actualizar') | Actualizar producto
        a(href='/eliminar') | Eliminar producto
        h2= message
        h3 productos

        table
            tr
                th Nombre
                th Unidades 
                th Precio
            each producto in productos.data
                tr 
                    td= producto.nombre 
                    td= producto.unidades 
                    td= producto.precio   